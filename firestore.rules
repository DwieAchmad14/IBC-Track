rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function isVerifiedEmail() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAuthorizedEditor() {
      return isVerifiedEmail() && (
        request.auth.token.email == 'dwieachmad14@gmail.com' ||
        request.auth.token.email == 'formulasiwaferjn3@gmail.com' ||
        request.auth.token.email.matches('.*@vibescoding\\.com') ||
        request.auth.token.email.matches('.*@vibescoding\\.id') ||
        exists(/databases/$(database)/documents/authorized_editors/$(request.auth.token.email))
      );
    }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidTank(data) {
      return data.keys().hasAll(['no']) &&
             data.no is string &&
             data.no.size() <= 200;
    }

    match /userSettings/{userId} {
      allow read, write: if (isSignedIn() && request.auth.uid == userId) || userId == 'user123';
    }

    match /appSettings/{document} {
      allow read: if true;
      allow write: if isAuthorizedEditor();
    }

    match /tanks/{tankId} {
      // Allow read for anyone
      allow read: if true;
      
      allow create: if isAuthorizedEditor() && 
                       isValidId(tankId) && 
                       isValidTank(incoming());
                       
      allow update: if isAuthorizedEditor() && 
                       isValidId(tankId) &&
                       isValidTank(incoming());
                       
      allow delete: if isAuthorizedEditor() && 
                       isValidId(tankId);
    }

    match /authorized_editors/{email} {
      allow read: if isVerifiedEmail();
      allow write: if isVerifiedEmail() && (
        request.auth.token.email == 'dwieachmad14@gmail.com' ||
        request.auth.token.email == 'formulasiwaferjn3@gmail.com'
      );
    }
  }
}
